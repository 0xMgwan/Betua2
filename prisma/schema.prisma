generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  walletAddress   String?
  ntzsUserId      String?          @unique
  username        String           @unique
  email           String           @unique
  phone           String?
  bio             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  avatarUrl       String?
  displayName     String?
  passwordHash        String
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  balanceTzs      Int              @default(0)
  referralCode    String?          @unique
  referredById    String?
  locale          String?          @default("en")
  balanceKes      Int              @default(0)
  balanceUsdc     Int              @default(0)  // stored in micro-USDC (6 decimals, so 1 USDC = 1000000)
  preferredCurrency String?        @default("TZS")  // TZS, KES, USDC, NGN
  country         String?          @default("TZ")
  comments        Comment[]
  eventsCreated   Event[]          @relation("EventCreator")
  marketsCreated  Market[]         @relation("MarketCreator")
  notifications   Notification[]
  positions       Position[]
  referralRewards ReferralReward[] @relation("ReferralRewardsEarned")
  trades          Trade[]
  referredBy      User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]           @relation("Referrals")
}

// Event container - groups multiple markets for the same real-world event
// e.g., "Liverpool vs Fulham" event contains markets for winner, first scorer, total goals, etc.
model Event {
  id          String    @id @default(cuid())
  title       String    // "Liverpool vs Fulham"
  description String?
  category    String    // "Sports"
  subCategory String?   // "EPL"
  imageUrl    String?
  startsAt    DateTime  // When the event starts (e.g., match kickoff)
  endsAt      DateTime? // When the event ends (optional)
  status      String    @default("UPCOMING") // UPCOMING, LIVE, ENDED
  creatorId   String
  partnerId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  markets     Market[]
  comments    Comment[]
  creator     User      @relation("EventCreator", fields: [creatorId], references: [id])
  partner     Partner?  @relation(fields: [partnerId], references: [id])

  @@index([category])
  @@index([startsAt])
  @@index([status])
  @@index([partnerId])
}

model Market {
  id           String     @id @default(cuid())
  eventId      String?    // NEW: Link to parent event (null for standalone markets)
  title        String
  description  String
  category     String
  subCategory  String?
  imageUrl     String?
  creatorId    String
  partnerId    String?
  currency     String     @default("TZS")
  status       String     @default("OPEN")
  outcome      Int?
  outcomeLabel String?
  resolvesAt   DateTime
  resolvedAt   DateTime?
  totalVolume  Int        @default(0)
  seedAmount   Int        @default(0)   // Real TZS seeded by creator at creation
  fxRate       Float?                   // Optional: TZS per foreign currency unit (for hedge calculator)
  yesPool      Int        @default(100000)
  noPool       Int        @default(100000)
  liquidity    Int        @default(200000)
  options      Json?
  optionPools  Json?
  optionImages Json?      // string[] of image URLs, index-aligned with options (per-team logos)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments     Comment[]
  event        Event?     @relation(fields: [eventId], references: [id])
  creator      User       @relation("MarketCreator", fields: [creatorId], references: [id])
  partner      Partner?   @relation(fields: [partnerId], references: [id])
  positions    Position[]
  trades       Trade[]

  @@index([eventId])
  @@index([partnerId])
}

model Position {
  id           String   @id @default(cuid())
  userId       String
  marketId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  noShares     Int      @default(0)
  yesShares    Int      @default(0)
  redeemed     Boolean  @default(false)
  optionShares Json?
  // Fixed-odds payout: net TZS owed to user if they win (accumulated across multiple trades)
  // Stored at trade time: tradeAmount / oddsPrice * (1 - settlementFeePercent)
  // Zero means old position — falls back to parimutuel formula at redemption
  yesImpliedPayout Float   @default(0)
  noImpliedPayout  Float   @default(0)
  optionImpliedPayouts Json? // { "0": 5000.0, "1": 2000.0 } for multi-option markets
  // LP seed shares: portion of yes/noShares that came from the creator's liquidity seed.
  // Trade shares = yesShares - lpYesShares (and same for no/options).
  // Portfolio hides positions with zero trade shares so the seed doesn't look like a bet.
  lpYesShares    Int  @default(0)
  lpNoShares     Int  @default(0)
  lpOptionShares Json? // { "0": 500, "1": 300 } mirror of optionShares for the seed portion
  market       Market   @relation(fields: [marketId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, marketId])
}

model Trade {
  id             String   @id @default(cuid())
  userId         String
  marketId       String
  shares         Int
  amountTzs      Int
  createdAt      DateTime @default(now())
  ntzsTransferId String?
  price          Float
  txHash         String?
  side           String
  isLpSeed       Boolean  @default(false)
  market         Market   @relation(fields: [marketId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  type              String
  amountTzs         Int      @default(0)
  amountUsdc        Int      @default(0)  // stored in micro-USDC (6 decimals)
  status            String   @default("PENDING")
  ntzsDepositId     String?
  ntzsWithdrawId    String?
  phone             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  recipientUsername String?
  amountKes         Int      @default(0)
  currency          String   @default("TZS")
  description       String?
  externalRef       String?
  txHash            String?

  @@index([externalRef])
}

model ReferralReward {
  id             String   @id @default(cuid())
  referrerId     String
  referredId     String
  depositTxId    String   @unique
  amountTzs      Int
  status         String   @default("PENDING")
  ntzsTransferId String?
  createdAt      DateTime @default(now())
  referrer       User     @relation("ReferralRewardsEarned", fields: [referrerId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  marketId  String?
  eventId   String?
  body      String
  createdAt DateTime @default(now())
  market    Market?   @relation(fields: [marketId], references: [id])
  event     Event?    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model MarketTranslation {
  id                String   @id @default(cuid())
  marketId          String
  language          String
  translatedTitle   String
  translatedDesc    String?
  translatedOptions Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([marketId, language])
  @@index([marketId])
}

model Partner {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  apiKey        String        @unique
  apiKeyPrefix  String
  webhookUrl    String?
  webhookSecret String?
  tier          String        @default("FREE")
  rateLimit     Int           @default(100)
  isActive      Boolean       @default(true)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isApproved    Boolean       @default(false)
  passwordHash  String?
  rawApiKey     String?
  earningsTzs   Int           @default(0) // accrued partner markup earnings (withdrawable)
  apiLogs       ApiLog[]
  events        Event[]
  markets       Market[]
  users         PartnerUser[]

  @@index([apiKey])
  @@index([apiKeyPrefix])
}

model PartnerUser {
  id         String   @id @default(cuid())
  partnerId  String
  externalId String
  userId     String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  partner    Partner  @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, externalId])
  @@index([partnerId])
  @@index([userId])
}

// Line-item ledger of partner markup earnings and payouts.
// amountTzs is positive for earnings, negative for payouts.
model PartnerEarning {
  id          String   @id @default(cuid())
  partnerId   String
  type        String // "TRADE_MARKUP" | "CREATION_MARKUP" | "PAYOUT"
  amountTzs   Int      @default(0)
  marketId    String?
  description String?
  createdAt   DateTime @default(now())

  @@index([partnerId, createdAt])
}

model ApiLog {
  id           String   @id @default(cuid())
  partnerId    String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  partner      Partner  @relation(fields: [partnerId], references: [id])

  @@index([partnerId, createdAt])
  @@index([createdAt])
}

model EmailSubscription {
  id           String   @id @default(cuid())
  email        String   @unique
  isActive     Boolean  @default(true)
  locale       String   @default("en")
  unsubscribeToken String @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  endpoint     String   @unique
  p256dh       String
  auth         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  pushEnabled           Boolean  @default(true)
  tradePlaced           Boolean  @default(true)
  positionExpiring      Boolean  @default(true)
  positionPriceChange   Boolean  @default(true)
  marketResolved        Boolean  @default(true)
  winnings              Boolean  @default(true)
  priceChangeThreshold  Int      @default(10)
  expiryWarningHours    Int      @default(24)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
