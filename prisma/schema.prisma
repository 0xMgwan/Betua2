generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  displayName   String?
  phone         String?
  bio           String?
  avatarUrl     String?
  passwordHash  String
  ntzsUserId    String?  @unique
  walletAddress String?
  referralCode  String?  @unique
  referredById  String?
  referredBy    User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("Referrals")
  balanceTzs    Int      @default(0)
  locale        String   @default("en")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  marketsCreated   Market[]          @relation("MarketCreator")
  positions        Position[]
  trades           Trade[]
  comments         Comment[]
  notifications    Notification[]
  referralRewards  ReferralReward[]  @relation("ReferralRewardsEarned")
}

model Market {
  id           String       @id @default(cuid())
  title        String
  description  String
  category     String
  subCategory  String?
  imageUrl     String?
  creatorId    String
  creator      User         @relation("MarketCreator", fields: [creatorId], references: [id])
  status       String       @default("OPEN")
  outcome      Int?
  outcomeLabel String?
  resolvesAt   DateTime
  resolvedAt   DateTime?
  totalVolume  Int          @default(0)
  yesPool      Int          @default(100000)
  noPool       Int          @default(100000)
  liquidity    Int          @default(200000)
  options      Json?
  optionPools  Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  positions Position[]
  trades    Trade[]
  comments  Comment[]
}

model Position {
  id           String   @id @default(cuid())
  userId       String
  marketId     String
  user         User     @relation(fields: [userId], references: [id])
  market       Market   @relation(fields: [marketId], references: [id])
  yesShares    Int      @default(0)
  noShares     Int      @default(0)
  optionShares Json?
  redeemed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, marketId])
}

model Trade {
  id             String   @id @default(cuid())
  userId         String
  marketId       String
  user           User     @relation(fields: [userId], references: [id])
  market         Market   @relation(fields: [marketId], references: [id])
  side           String
  amountTzs      Int
  shares         Int
  price          Float
  txHash         String?
  ntzsTransferId String?
  createdAt      DateTime @default(now())
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  type              String
  amountTzs         Int
  status            String   @default("PENDING")
  ntzsDepositId     String?
  ntzsWithdrawId    String?
  phone             String?
  recipientUsername String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ReferralReward {
  id            String   @id @default(cuid())
  referrerId    String
  referrer      User     @relation("ReferralRewardsEarned", fields: [referrerId], references: [id])
  referredId    String
  depositTxId   String   @unique
  amountTzs     Int
  status        String   @default("PENDING")
  ntzsTransferId String?
  createdAt     DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  user      User     @relation(fields: [userId], references: [id])
  market    Market   @relation(fields: [marketId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model MarketTranslation {
  id               String   @id @default(cuid())
  marketId         String
  language         String
  translatedTitle  String
  translatedDesc   String?
  translatedOptions Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([marketId, language])
  @@index([marketId])
}
