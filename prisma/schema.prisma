generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  walletAddress   String?
  ntzsUserId      String?          @unique
  username        String           @unique
  email           String           @unique
  phone           String?
  bio             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  avatarUrl       String?
  displayName     String?
  passwordHash    String
  balanceTzs      Int              @default(0)
  referralCode    String?          @unique
  referredById    String?
  locale          String?          @default("en")
  balanceKes      Int              @default(0)
  country         String?          @default("TZ")
  comments        Comment[]
  marketsCreated  Market[]         @relation("MarketCreator")
  notifications   Notification[]
  positions       Position[]
  referralRewards ReferralReward[] @relation("ReferralRewardsEarned")
  trades          Trade[]
  referredBy      User?            @relation("Referrals", fields: [referredById], references: [id])
  referrals       User[]           @relation("Referrals")
}

model Market {
  id           String     @id @default(cuid())
  description  String
  category     String
  imageUrl     String?
  creatorId    String
  resolvedAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  liquidity    Int        @default(200000)
  noPool       Int        @default(100000)
  outcome      Int?
  resolvesAt   DateTime
  title        String
  totalVolume  Int        @default(0)
  yesPool      Int        @default(100000)
  status       String     @default("OPEN")
  optionPools  Json?
  options      Json?
  outcomeLabel String?
  subCategory  String?
  partnerId    String?
  comments     Comment[]
  creator      User       @relation("MarketCreator", fields: [creatorId], references: [id])
  partner      Partner?   @relation(fields: [partnerId], references: [id])
  positions    Position[]
  trades       Trade[]

  @@index([partnerId])
}

model Position {
  id           String   @id @default(cuid())
  userId       String
  marketId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  noShares     Int      @default(0)
  yesShares    Int      @default(0)
  redeemed     Boolean  @default(false)
  optionShares Json?
  market       Market   @relation(fields: [marketId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, marketId])
}

model Trade {
  id             String   @id @default(cuid())
  userId         String
  marketId       String
  shares         Int
  amountTzs      Int
  createdAt      DateTime @default(now())
  ntzsTransferId String?
  price          Float
  txHash         String?
  side           String
  market         Market   @relation(fields: [marketId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id                String   @id @default(cuid())
  userId            String
  type              String
  amountTzs         Int      @default(0)
  status            String   @default("PENDING")
  ntzsDepositId     String?
  ntzsWithdrawId    String?
  phone             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  recipientUsername String?
  amountKes         Int      @default(0)
  currency          String   @default("TZS")
  description       String?
  externalRef       String?
  txHash            String?

  @@index([externalRef])
}

model ReferralReward {
  id             String   @id @default(cuid())
  referrerId     String
  referredId     String
  depositTxId    String   @unique
  amountTzs      Int
  status         String   @default("PENDING")
  ntzsTransferId String?
  createdAt      DateTime @default(now())
  referrer       User     @relation("ReferralRewardsEarned", fields: [referrerId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  body      String
  createdAt DateTime @default(now())
  market    Market   @relation(fields: [marketId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model MarketTranslation {
  id                String   @id @default(cuid())
  marketId          String
  language          String
  translatedTitle   String
  translatedDesc    String?
  translatedOptions Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([marketId, language])
  @@index([marketId])
}

model Partner {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  apiKey        String        @unique
  apiKeyPrefix  String
  webhookUrl    String?
  webhookSecret String?
  tier          String        @default("FREE")
  rateLimit     Int           @default(100)
  isActive      Boolean       @default(true)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isApproved    Boolean       @default(false)
  passwordHash  String?
  rawApiKey     String?
  apiLogs       ApiLog[]
  markets       Market[]
  users         PartnerUser[]

  @@index([apiKey])
  @@index([apiKeyPrefix])
}

model PartnerUser {
  id         String   @id @default(cuid())
  partnerId  String
  externalId String
  userId     String
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  partner    Partner  @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, externalId])
  @@index([partnerId])
  @@index([userId])
}

model ApiLog {
  id           String   @id @default(cuid())
  partnerId    String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  partner      Partner  @relation(fields: [partnerId], references: [id])

  @@index([partnerId, createdAt])
  @@index([createdAt])
}
