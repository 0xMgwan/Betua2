# Database
DATABASE_URL="file:./dev.db"

# NTZS API
NTZS_API_KEY="ntzs_live_xxxx"
NTZS_BASE_URL="https://www.ntzs.co.tz"

# Auth
JWT_SECRET="your-super-secret-jwt-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform wallet (nTZS user ID for escrow)
PLATFORM_NTZS_USER_ID=""

# Fee wallets (nTZS user IDs — set these to the nTZS user IDs for the fee wallets)
# Creation fee wallet (wallet address: 0x0e771Dc7ccf819C21a23d6ddd4E0CD93AfC21a21)
CREATION_FEE_NTZS_USER_ID=""

# Settlement/transaction fee wallet (wallet address: 0x925a0e7Df09a56d7d7fE3D9236428affAbC20D4f)
SETTLEMENT_FEE_NTZS_USER_ID=""

# Fee amounts (defaults shown)
MARKET_CREATION_FEE_TZS=2000
TRANSACTION_FEE_PERCENT=5
